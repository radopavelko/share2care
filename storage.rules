rules_version = '2';
// Share2 — item photos live under items/{uid}/...
// Anyone signed in can view photos; you can only upload under your own uid,
// images only, max 8 MB (uploads are downscaled client-side before sending).
service firebase.storage {
  match /b/{bucket}/o {
    match /items/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
